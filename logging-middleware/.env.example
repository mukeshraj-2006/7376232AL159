# ============================================
# Logging Middleware — Environment Configuration
# ============================================

# Remote logging API endpoint
LOG_API_URL=http://4.224.186.213/evaluation-service/logs

# Application name (used in log metadata)
APP_NAME=campus-notifications

# Environment: development | staging | production
NODE_ENV=development

# Request timeout in milliseconds
LOG_TIMEOUT_MS=5000

# Maximum retry attempts
LOG_MAX_RETRIES=3

# Enable console logging fallback (true/false)
LOG_CONSOLE_FALLBACK=true
